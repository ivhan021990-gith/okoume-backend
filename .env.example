# ─── BASE DE DONNÉES ───────────────────────────────────────────────
# PostgreSQL (ex: Supabase, Railway, Render)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/okoume_db"

# ─── SERVEUR ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8081

# ─── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=votre_secret_jwt_tres_long_et_securise_ici
JWT_EXPIRES_IN=30d

# ─── SMS OTP — Africa's Talking ────────────────────────────────────
# Créez un compte sur africastalking.com
AT_API_KEY=votre_api_key_africas_talking
AT_USERNAME=votre_username
AT_SENDER_ID=OKOUME       # ID expéditeur (max 11 caractères)

# ─── CLOUDINARY (stockage photos) ──────────────────────────────────
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ─── PAIEMENT — CinetPay (Mobile Money Gabon) ──────────────────────
# Créez un compte sur cinetpay.com
CINETPAY_API_KEY=votre_api_key_cinetpay
CINETPAY_SITE_ID=votre_site_id
CINETPAY_SECRET_KEY=votre_secret_key
CINETPAY_NOTIFY_URL=https://votre-domaine.com/api/payments/webhook

# ─── ADMIN ─────────────────────────────────────────────────────────
ADMIN_SECRET=votre_secret_admin_pour_les_endpoints_proteges
