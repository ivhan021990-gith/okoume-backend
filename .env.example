# ─── BASE DE DONNÉES ───────────────────────────────────────────────
# PostgreSQL (ex: Supabase, Railway, Render)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/itonda_db"

# ─── SERVEUR ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=https://votre-domaine.com
FRONTEND_URL=http://localhost:8081

# ─── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=votre_secret_jwt_tres_long_et_securise_ici
JWT_EXPIRES_IN=30d

# ─── SMS OTP — Africa's Talking ────────────────────────────────────
# Créez un compte sur africastalking.com
AT_API_KEY=votre_api_key_africas_talking
AT_USERNAME=votre_username
AT_SENDER_ID=ITONDA        # ID expéditeur (max 11 caractères)

# ─── PAIEMENT — SingPay (Mobile Money Gabon) ───────────────────────
# Créez un compte sur singpay.ga
SINGPAY_CLIENT_ID=votre_client_id_singpay
SINGPAY_CLIENT_SECRET=votre_client_secret_singpay
SINGPAY_WALLET_ID=votre_wallet_id_singpay
# Secret HMAC pour vérifier les webhooks entrants de SingPay
SINGPAY_WEBHOOK_SECRET=votre_secret_webhook_singpay

# ─── CLOUDINARY (stockage photos) ──────────────────────────────────
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ─── ADMIN ─────────────────────────────────────────────────────────
# Envoyé dans le header X-Admin-Secret pour les routes d'administration
ADMIN_SECRET=votre_secret_admin_tres_long_et_securise
